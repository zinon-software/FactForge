# FactForge — API Keys
# Copy this file to config/.env and fill in your keys
# NEVER commit config/.env to git

# Kling AI via fal.ai (free tier: 66 credits/day, pay-per-use after)
# Get key at: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_api_key_here

# Runway ML Gen-4 (125 free credits one-time, then paid)
# Get key at: https://app.runwayml.com/settings → API
RUNWAYML_API_SECRET=your_runway_api_key_here

# YouTube API (already configured)
# YOUTUBE_CLIENT_ID=...
# YOUTUBE_CLIENT_SECRET=...

# Pexels (for stock footage fallback)
# PEXELS_API_KEY=...
