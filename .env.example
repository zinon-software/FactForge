# YouTube Automation System — Environment Variables
# Copy this file to .env and fill in ALL values before running

# ─────────────────────────────────────────────
# Anthropic (Claude API)
# Get from: https://console.anthropic.com/keys
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# YouTube OAuth2 Credentials
# Get from: https://console.cloud.google.com
# See README.md for full setup instructions
# ─────────────────────────────────────────────
YOUTUBE_CREDENTIALS_PATH=config/youtube_credentials.json
YOUTUBE_TOKEN_PATH=config/youtube_token.json
YOUTUBE_CHANNEL_ID=

# ─────────────────────────────────────────────
# Pexels API (free stock video/images)
# Get from: https://www.pexels.com/api/
# ─────────────────────────────────────────────
PEXELS_API_KEY=

# ─────────────────────────────────────────────
# Serper API (Google Search)
# Get from: https://serper.dev
# ─────────────────────────────────────────────
SERPER_API_KEY=

# ─────────────────────────────────────────────
# System Settings (safe defaults — adjust as needed)
# ─────────────────────────────────────────────
OUTPUT_DIR=output
DATABASE_DIR=database
STATE_DIR=state
MAX_SHORT_DURATION=58
MAX_LONG_DURATION=900
PUBLISH_INTERVAL_HOURS=48
TIMEZONE=UTC
