  "placement_rules": {
    "_comment": "Controls WHEN SFX fires \u2014 prevents over-saturation",
    "max_sfx_per_40s": 5,
    "min_gap_between_sfx_ms": 3000,
    "hook_sfx_mandatory": true,
    "hook_sfx_offset_ms": 0,
    "stat_sfx_on_number_words": true,
    "impact_sfx_on_impact_segments": true,
    "transition_sfx_max_count": 3,
    "transition_sfx_on_segments": [
      1,
      4,
      8,
      12
    ],
    "final_segment_sfx": "reveal_sting",
    "final_segment_volume": 0.2
  },
  "3_tier_audio": {
    "_comment": "3-tier audio layering: BGM + SFX + Ambient",
    "tier1_bgm": {
      "volume": 0.08,
      "type": "ambient_documentary",
      "path": "assets/ambient_documentary.mp3",
      "fade_in_s": 1.0,
      "fade_out_s": 2.0
    },
    "tier2_sfx": {
      "volume_multiplier": 1.0,
      "ducking_while_sfx": false
    },
    "tier3_ambient": {
      "enabled": false,
      "_note": "Future: topic-specific ambient bed (ocean waves, city noise, etc.)"
    }
  },
  "vocal_humanization": {
    "_comment": "TTS parameters for natural-sounding speech",
    "speed_base": 1.08,
    "pause_after_hook_ms": 400,
    "pause_after_stat_ms": 300,
    "pause_after_impact_ms": 500,
    "pause_between_sentences_ms": 200,
    "dramatic_pause_trigger_words": [
      "but",
      "however",
      "yet",
      "instead",
      "actually",
      "wait",
      "only",
      "just"
    ],
    "dramatic_pause_duration_ms": 350
  },
  "hook_optimization": {
    "_comment": "First 1.5 seconds must be high-impact",
    "max_hook_words": 12,
    "hook_must_contain_shock_word": true,
    "shock_words": [
      "never",
      "impossible",
      "zero",
      "only",
      "less than",
      "more than",
      "billion",
      "million",
      "discovered",
      "banned",
      "secret",
      "hidden",
      "nobody",
      "everybody"
    ],
    "hook_segment_type": "hook",
    "hook_visual_rule": "zoom-in",
    "hook_sfx_mandatory": true
  },
  "real_assets_dir": "audio_engineering/assets/sfx_real",
  "prefer_real_assets": true
}